{
  "name": "hotstuff-market-cli",
  "version": "0.1.1",
  "description": "Hotstuff market + trading CLI powered by the official TypeScript SDK.",
  "type": "module",
  "preferGlobal": true,
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "hotstuff-market": "cli.mjs",
    "hotstuff": "cli.mjs",
    "cli": "cli.mjs"
  },
  "files": [
    "cli.mjs",
    "src",
    "README.md"
  ],
  "scripts": {
    "cli": "node ./cli.mjs",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "hotstuff",
    "cli",
    "trading",
    "orders",
    "market-data",
    "sdk"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hotstuff-labs/ts-sdk": "^0.1.1-beta.10",
    "chalk": "^5.6.2"
  }
}
