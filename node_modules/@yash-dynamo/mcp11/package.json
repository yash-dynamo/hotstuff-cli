{
  "name": "@yash-dynamo/mcp11",
  "version": "0.1.1",
  "private": false,
  "description": "MCP server for Hotstuff Labs built on the published Hotstuff TypeScript SDK",
  "type": "module",
  "bin": {
    "mcp-server-hotstuff": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --noEmit -p tsconfig.json && node esbuild.config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "npm run build && husky || true",
    "dev": "node esbuild.config.mjs --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hotstuff-labs/ts-sdk": "0.0.1-beta.10",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "viem": "^2.34.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0"
  }
}
